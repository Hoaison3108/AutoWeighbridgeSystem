<UserControl x:Class="AutoWeighbridgeSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:AutoWeighbridgeSystem.Converters"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Background="#121212" Foreground="White"
             d:DesignHeight="900" d:DesignWidth="1280">

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:HardwareStatusToColorConverter x:Key="HardwareStatusToColorConverter"/>

        <Style x:Key="StabilityLightStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#E53935"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsScaleStable}" Value="True">
                    <Setter Property="Fill" Value="#00E676"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#EEEEEE" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black" />
            </Style.Resources>
            <!-- Khi ở Auto Mode (IsEnabled=False): làm mờ để người dùng biết không thể chỉnh -->
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#252525"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="BorderBrush" Value="#1976D2"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenterAlignedColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RightAlignedColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <!-- Nút bật tắt ComboBox siêu to khổng lồ dành cho trạm cân cảm ứng (Touch-friendly) -->
        <Style x:Key="BigDropdownButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="50"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Background" Value="#455A64"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="▼" FontFamily="Segoe UI Symbol" FontSize="20" FontWeight="Bold" Margin="0,2,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00E676"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <!-- TRÁI: Logo bar + Tiêu đề -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#2196F3" Width="4" Height="20" Margin="0,0,10,0"/>
                <TextBlock Text="KHOÁNG SẢN RẠNG ĐÔNG - ĐIỀU HÀNH TRẠM CÂN"
                           FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="#AAA"/>
            </StackPanel>

            <!-- PHẢI: Status Panel + Đồng hồ -->
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- Hardware Connection Status Mini Panel -->
                <Border Background="#1A1A1A" CornerRadius="6" Padding="10,4"
                        BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,16,0"
                        ToolTip="Trạng thái kết nối thiết bị phần cứng">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Đầu cân -->
                        <StackPanel Margin="0,0,10,0"
                                    ToolTip="{Binding ScaleConnectionStatus, StringFormat='Đầu cân: {0}'}">
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                     Fill="{Binding ScaleConnectionStatus, Converter={StaticResource HardwareStatusToColorConverter}}"/>
                            <TextBlock Text="CÂN" FontSize="8" FontWeight="Bold"
                                       Foreground="#666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- RFID Vào -->
                        <StackPanel Margin="0,0,10,0"
                                    ToolTip="{Binding RfidInStatus, StringFormat='RFID Vào: {0}'}">
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                     Fill="{Binding RfidInStatus, Converter={StaticResource HardwareStatusToColorConverter}}"/>
                            <TextBlock Text="RFID-V" FontSize="8" FontWeight="Bold"
                                       Foreground="#666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- RFID Ra -->
                        <StackPanel Margin="0,0,10,0"
                                    ToolTip="{Binding RfidOutStatus, StringFormat='RFID Ra: {0}'}">
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                     Fill="{Binding RfidOutStatus, Converter={StaticResource HardwareStatusToColorConverter}}"/>
                            <TextBlock Text="RFID-R" FontSize="8" FontWeight="Bold"
                                       Foreground="#666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- RFID Bàn -->
                        <StackPanel Margin="0,0,10,0"
                                    ToolTip="{Binding RfidDeskStatus, StringFormat='RFID Bàn: {0}'}">
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                     Fill="{Binding RfidDeskStatus, Converter={StaticResource HardwareStatusToColorConverter}}"/>
                            <TextBlock Text="BÀN" FontSize="8" FontWeight="Bold"
                                       Foreground="#666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Camera -->
                        <StackPanel
                                    ToolTip="{Binding CameraConnectionStatus, StringFormat='Camera: {0}'}">
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                     Fill="{Binding CameraConnectionStatus, Converter={StaticResource HardwareStatusToColorConverter}}"/>
                            <TextBlock Text="CAM" FontSize="8" FontWeight="Bold"
                                       Foreground="#666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- Đồng hồ -->
                <TextBlock Text="{Binding Clock.CurrentTime, StringFormat='dd/MM/yyyy HH:mm:ss'}"
                           VerticalAlignment="Center" Foreground="#2196F3" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="550"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,0,15,0" BorderBrush="#333" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="PHIẾU CÂN" FontSize="18" FontWeight="Bold" Foreground="#2196F3" VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                            <ToggleButton IsChecked="{Binding IsOnePassMode}" Width="100" Height="28" Cursor="Hand" Margin="0,0,10,0">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Content" Value="Mode 2"/>
                                        <Setter Property="Background" Value="#424242"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content" Value="Mode 1"/>
                                                <Setter Property="Background" Value="#00E676"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <ToggleButton IsChecked="{Binding IsAutoMode}" Width="100" Height="28" Cursor="Hand">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Content" Value="MANUAL"/>
                                        <Setter Property="Background" Value="#424242"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content" Value="AUTO"/>
                                                <Setter Property="Background" Value="#00E676"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#0A0A0A" CornerRadius="8" Padding="10,5" Margin="0,0,0,12" BorderBrush="#2196F3" BorderThickness="1">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="TRỌNG LƯỢNG (KG)" FontSize="10" Foreground="#555" FontWeight="Bold"/>
                                <Ellipse Style="{StaticResource StabilityLightStyle}" Width="12" Height="12" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="{Binding WeightDisplay}" FontSize="52" FontFamily="Consolas" FontWeight="Bold" Foreground="#00E676" HorizontalAlignment="Center" Margin="0,-5,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00E676" BlurRadius="10" ShadowDepth="0"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <Border Background="#33FF0000" CornerRadius="4" Padding="5,2" Margin="0,2,0,0"
                                    Visibility="{Binding IsWeightLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock HorizontalAlignment="Center" Foreground="#FF5252" FontWeight="Bold" FontSize="13">
                                    <Run Text="🔒 ĐÃ CHỐT: "/>
                                    <Run Text="{Binding LockedWeight, StringFormat=N0}"/>
                                    <Run Text=" KG"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding RfidLocationLabel}" Foreground="#00E676"/>
                            <TextBox Text="{Binding RfidInput, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Height="45" FontSize="18" Background="#111" Foreground="#00E676" BorderBrush="#00E676" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Padding="10,0" Margin="0,0,0,15">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ProcessRfidCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="BIỂN SỐ XE (GÕ TRỰC TIẾP KHI MANUAL)"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6*"/>
                                    <ColumnDefinition Width="4*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="{Binding IsAutoMode}" 
                     Height="45" FontSize="18" Background="#2D2D2D" Foreground="#2196F3" 
                     VerticalContentAlignment="Center" Padding="10,0" FontWeight="Bold" Margin="0,0,5,0"/>
                                <!-- IsEnabled=IsManualMode: chỉ cho phép dùng ComboBox khi ở chế độ Manual -->
                                <!-- IsEditable=True + TextChanged: tạo hiệu ứng filter-as-you-type autocomplete -->
                                <ComboBox x:Name="VehicleComboBox"
                                          Grid.Column="1"
                                          ItemsSource="{Binding VehicleAutocomplete.View}"
                                          Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          IsEnabled="{Binding IsManualMode}"
                                          Height="45" FontSize="18"
                                          TextBoxBase.TextChanged="VehicleComboBox_TextChanged"
                                          ToolTip="Gõ để lọc danh sách xe — chỉ khả dụng ở chế độ Manual"/>
                                          
                                <!-- Phép thuật phủ nút to gấp 3 lần nút mặc định của WPF -->
                                <ToggleButton Grid.Column="1" 
                                              Style="{StaticResource BigDropdownButtonStyle}" 
                                              IsChecked="{Binding IsDropDownOpen, ElementName=VehicleComboBox}" 
                                              IsEnabled="{Binding IsManualMode}"/>
                            </Grid>

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="KHÁCH HÀNG (GÕ TRỰC TIẾP KHI MANUAL)"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6*"/>
                                    <ColumnDefinition Width="4*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="{Binding IsAutoMode}" 
                     Height="45" Background="#2D2D2D" Foreground="White" 
                     VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,5,0" FontSize="16"/>
                                <ComboBox x:Name="CustomerComboBox"
                                          Grid.Column="1"
                                          ItemsSource="{Binding CustomerAutocomplete.View}"
                                          Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          IsEnabled="{Binding IsManualMode}"
                                          Height="45" FontSize="16"
                                          TextBoxBase.TextChanged="CustomerComboBox_TextChanged"
                                          ToolTip="Gõ để lọc danh sách khách hàng — chỉ khả dụng ở chế độ Manual"/>
                                          
                                <ToggleButton Grid.Column="1" 
                                              Style="{StaticResource BigDropdownButtonStyle}" 
                                              IsChecked="{Binding IsDropDownOpen, ElementName=CustomerComboBox}" 
                                              IsEnabled="{Binding IsManualMode}"/>
                            </Grid>

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="LOẠI HÀNG (GÕ TRỰC TIẾP KHI MANUAL)"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6*"/>
                                    <ColumnDefinition Width="4*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="{Binding IsAutoMode}" 
                     Height="45" Background="#2D2D2D" Foreground="White" 
                     VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,5,0" FontSize="16"/>
                                <ComboBox x:Name="ProductComboBox"
                                          Grid.Column="1"
                                          ItemsSource="{Binding ProductAutocomplete.View}"
                                          Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          IsEnabled="{Binding IsManualMode}"
                                          Height="45" FontSize="16"
                                          TextBoxBase.TextChanged="ProductComboBox_TextChanged"
                                          ToolTip="Gõ để lọc danh sách hàng hóa — chỉ khả dụng ở chế độ Manual"/>
                                          
                                <ToggleButton Grid.Column="1" 
                                              Style="{StaticResource BigDropdownButtonStyle}" 
                                              IsChecked="{Binding IsDropDownOpen, ElementName=ProductComboBox}" 
                                              IsEnabled="{Binding IsManualMode}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding RefreshFormCommand}" Height="48" Margin="0,0,3,0" Cursor="Hand" ToolTip="Làm sạch biểu mẫu (Xóa trắng)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#455A64"/>
                                    <Setter Property="Content" Value="♻️ LÀM MỚI"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="1" Command="{Binding ToggleWeightLockCommand}" Height="48" Margin="3,0,3,0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#3F51B5"/>
                                    <Setter Property="Content" Value="🔒 CHỐT SỐ"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWeightLocked}" Value="True">
                                            <Setter Property="Background" Value="#D32F2F"/>
                                            <Setter Property="Content" Value="🔓 HỦY CHỐT"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2" Command="{Binding ManualSaveCommand}" Content="💾 LƯU PHIẾU" Height="48" Margin="3,0,3,0" FontWeight="Bold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#2196F3"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="IsEnabled" Value="{Binding IsManualMode}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.3"/>
                                            <Setter Property="Cursor" Value="No"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="3" Command="{Binding TriggerManualAlarmCommand}" Content="🔔 HÚ CÒI" Height="48" Margin="3,0,0,0" Background="#FF9800" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="Black" CornerRadius="12" BorderBrush="#333" BorderThickness="2" ClipToBounds="True">
                <Grid>
                    <vlc:VideoView x:Name="CameraPlayer" Background="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                    <Border Background="#AA000000" VerticalAlignment="Top" Padding="12" Visibility="{Binding CameraStatus, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding CameraStatus}" Foreground="Yellow" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="12" Padding="15" Margin="0,15,0,0" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="NHẬT KÝ VẬN HÀNH (DỮ LIỆU TRONG NGÀY)" FontSize="14" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding RecentTickets}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                          SelectedItem="{Binding SelectedRecentTicket}">
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding CopyDataFromTicketCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding TicketID}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Biển Số" Binding="{Binding LicensePlate}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#2196F3"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Khách Hàng" Binding="{Binding CustomerName}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Loại Hàng" Binding="{Binding ProductName}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#00E676"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tổng (Kg)" Binding="{Binding GrossWeight, StringFormat=N0}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Thân (Kg)" Binding="{Binding TareWeight, StringFormat=N0}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Hàng (Kg)" Binding="{Binding NetWeight, StringFormat=N0}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#00E676"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Giờ Vào" Binding="{Binding TimeIn, StringFormat='HH:mm:ss'}" Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Giờ Ra" Binding="{Binding TimeOut, StringFormat='HH:mm:ss'}" Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Đợi cân lần 2">
                                            <Setter Property="Foreground" Value="#FFEB3B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Đã Hoàn Thành">
                                            <Setter Property="Foreground" Value="#00E676"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Bị Hủy">
                                            <Setter Property="Foreground" Value="#E53935"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
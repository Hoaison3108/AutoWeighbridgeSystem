<UserControl x:Class="AutoWeighbridgeSystem.Views.ManualTicketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="850"
             Background="#0F0F0F" Foreground="White"
             FontFamily="Segoe UI Semibold">
    
    <UserControl.Resources>
        <!-- Glassmorphism Effect for Cards -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- Modern Input Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="15"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#EEEEEE" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black" />
                
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="10,8"/>
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="SelectionBrush" Value="#2196F3"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernDropdownButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="50"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Background" Value="#455A64"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0,6,6,0">
                            <TextBlock Text="▼" FontFamily="Segoe UI Symbol" FontSize="18" FontWeight="Bold" Margin="0,2,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00E676"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Body -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111" Padding="25,20" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#D32F2F" Width="4" Height="24" CornerRadius="2" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="NHẬP DỮ LIỆU CÂN THỦ CÔNG" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Chế độ bỏ qua kiểm soát phần cứng - Sử dụng khi xảy ra sự cố thiết bị" FontSize="11" Foreground="#555" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Form Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="DỰ LIỆU CƠ BẢN" Foreground="#2196F3" FontSize="11" FontWeight="Bold" Margin="5,0,0,10" Opacity="0.8"/>
                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="BIỂN SỐ XE (*)" Style="{StaticResource FieldLabelStyle}"/>
                            <Grid Margin="0,0,0,15">
                                <ComboBox x:Name="VehicleCombo" ItemsSource="{Binding AvailableVehicles}" 
                                          Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"/>
                                <ToggleButton Style="{StaticResource ModernDropdownButtonStyle}" IsChecked="{Binding IsDropDownOpen, ElementName=VehicleCombo}"/>
                            </Grid>

                            <TextBlock Text="KHÁCH HÀNG / ĐƠN VỊ" Style="{StaticResource FieldLabelStyle}"/>
                            <Grid Margin="0,0,0,15">
                                <ComboBox x:Name="CustomerCombo" ItemsSource="{Binding AvailableCustomers}"
                                          Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"/>
                                <ToggleButton Style="{StaticResource ModernDropdownButtonStyle}" IsChecked="{Binding IsDropDownOpen, ElementName=CustomerCombo}"/>
                            </Grid>

                            <TextBlock Text="LOẠI HÀNG HÓA" Style="{StaticResource FieldLabelStyle}"/>
                            <Grid>
                                <ComboBox x:Name="ProductCombo" ItemsSource="{Binding AvailableProducts}"
                                          Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"/>
                                <ToggleButton Style="{StaticResource ModernDropdownButtonStyle}" IsChecked="{Binding IsDropDownOpen, ElementName=ProductCombo}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="THỜI GIAN GHI NHẬN" Foreground="#2196F3" FontSize="11" FontWeight="Bold" Margin="5,10,0,10" Opacity="0.8"/>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="THỜI GIAN VÀO" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding TimeIn, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="13" Foreground="#999"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="THỜI GIAN RA" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding TimeOut, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="13" Foreground="#999"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="THÔNG SỐ KHỐI LƯỢNG" Foreground="#FF9800" FontSize="11" FontWeight="Bold" Margin="5,0,0,10" Opacity="0.8"/>
                    <Border Style="{StaticResource CardStyle}" BorderBrush="#333">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="TỔNG TRỌNG (GROSS)" Style="{StaticResource FieldLabelStyle}" Foreground="#FFC107"/>
                                    <TextBox Text="{Binding GrossWeight, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#242010" Foreground="#FFC107" BorderBrush="#440" 
                                             FontWeight="Bold" FontSize="18" Height="50" HorizontalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="THÂN XE (TARE)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding TareWeight, UpdateSourceTrigger=PropertyChanged}" 
                                             FontWeight="Bold" FontSize="18" Height="50" HorizontalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#111" CornerRadius="8" Margin="0,20,0,0" Padding="15" BorderBrush="#00E676" BorderThickness="0,0,0,2">
                                <StackPanel>
                                    <TextBlock Text="TRỌNG LƯỢNG HÀNG THỰC (NET)" Foreground="#00E676" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding NetWeight, StringFormat={}{0:N0} KG}" FontSize="36" FontWeight="Bold" Foreground="#00E676" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CAM KẾT &amp; CHỨNG TỪ" Foreground="#FF5252" FontSize="11" FontWeight="Bold" Margin="5,10,0,10" Opacity="0.8"/>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="LÝ DO NHẬP THỦ CÔNG (*)" Style="{StaticResource FieldLabelStyle}" Foreground="#FF5252"/>
                            <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" 
                                     Height="80" VerticalContentAlignment="Top" Padding="12" AcceptsReturn="True" TextWrapping="Wrap" FontSize="14"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#111" Padding="25,20" BorderBrush="#222" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="(*) Thông tin bắt buộc" VerticalAlignment="Center" Foreground="#444" FontSize="11"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CancelCommand}" Content="❌ HỦY BỎ" Width="120" Height="42" Background="Transparent" Foreground="#777" BorderBrush="#333" Margin="0,0,10,0" Cursor="Hand"/>
                    <Button Command="{Binding SaveCommand}" Content="💾 XÁC NHẬN LƯU PHIẾU" 
                            Width="200" Height="42" Background="#D32F2F" Foreground="White" 
                            FontWeight="Bold" FontSize="14" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

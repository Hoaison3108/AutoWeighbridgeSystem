<UserControl x:Class="AutoWeighbridgeSystem.Views.LicenseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoWeighbridgeSystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100" Background="#121212">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER SECTION -->
        <StackPanel Grid.Row="0" Margin="0,0,0,45">
            <TextBlock Text="QUẢN LÝ BẢN QUYỀN" FontSize="22" FontWeight="Bold" Foreground="#2196F3"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: LICENSE DETAILS CARD -->
            <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="24" Padding="40" Margin="0,0,30,0" 
                    BorderBrush="#2A2A2A" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Opacity="0.15" ShadowDepth="0"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="THÔNG TIN CHI TIẾT" FontSize="13" FontWeight="Bold" Foreground="#555" Margin="0,0,0,35"/>

                    <!-- RIGID GRID STRUCTURE FOR PERFECT ALIGNMENT -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/> <!-- Row 0: Machine ID -->
                            <RowDefinition Height="60"/> <!-- Row 1: Customer -->
                            <RowDefinition Height="50"/> <!-- Row 2: Status -->
                            <RowDefinition Height="50"/> <!-- Row 3: Expiry -->
                            <RowDefinition Height="70"/> <!-- Row 4: Remaining -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>  <!-- Column 0: Icon -->
                            <ColumnDefinition Width="145"/> <!-- Column 1: Label -->
                            <ColumnDefinition Width="*"/>   <!-- Column 2: Value -->
                        </Grid.ColumnDefinitions>

                        <!-- MACHINE ID -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="🆔" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Mã Máy (ID):" Foreground="#888" FontSize="14" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#121212" CornerRadius="10" Padding="16,10" BorderBrush="#333" BorderThickness="1">
                                <TextBlock Text="{Binding HardwareId}" Foreground="#00E676" FontFamily="Consolas" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                            <Button Command="{Binding CopyHardwareIdCommand}" Content="📋 SAO CHÉP" 
                                    Margin="12,0,0,0" Padding="15,0" Height="42" Background="#2D2D2D" Foreground="White" FontSize="12" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <!-- CUSTOMER -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="🏢" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Khách Hàng:" Foreground="#888" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CustomerName}" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>

                        <!-- STATUS -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="⚡" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Trạng Thái:" Foreground="#888" FontSize="14" VerticalAlignment="Center"/>
                        <Border Grid.Row="2" Grid.Column="2" Background="#1A3326" HorizontalAlignment="Left" CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                             <TextBlock Text="{Binding LicenseStatus}" Foreground="Yellow" FontSize="13" FontWeight="Bold"/>
                        </Border>

                        <!-- EXPIRY DATE -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="📅" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Ngày Hết Hạn:" Foreground="#888" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ExpiryDate}" Foreground="#DDD" FontSize="16" VerticalAlignment="Center"/>

                        <!-- REMAINING DAYS -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="⏳" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Còn Lại:" Foreground="#888" FontSize="14" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RemainingDays}" Foreground="#00E676" FontSize="36" FontWeight="Black" VerticalAlignment="Center"/>
                            <TextBlock Text="ngày sử dụng" Foreground="#555" Margin="12,0,0,8" VerticalAlignment="Bottom" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- RIGHT COLUMN: ACTIONS & GUIDE -->
            <StackPanel Grid.Column="1">
                <!-- ACTION CARD -->
                <Border Background="#1A1A1A" CornerRadius="24" Padding="35" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,0,30"
                        IsEnabled="{Binding IsAdmin}">
                    <StackPanel>
                        <TextBlock Text="KÍCH HOẠT" FontSize="13" FontWeight="Bold" Foreground="#555" Margin="0,0,0,25"/>
                        
                        <Button Command="{Binding ActivateLicenseCommand}" Content="🔓 KÍCH HOẠT BẢN QUYỀN" 
                                Height="65" Background="#00E676" Foreground="#121212" FontSize="16" FontWeight="Black" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="14"/></Style>
                            </Button.Resources>
                        </Button>

                        <Button Command="{Binding RefreshLicenseInfoCommand}" Content="🔄 LÀM MỚI" 
                                Margin="0,15,0,0" Height="48" Background="#2D2D2D" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                            </Button.Resources>
                        </Button>

                        <Button Command="{Binding DeactivateLicenseCommand}" Content="❌ HỦY BẢN QUYỀN" 
                                Margin="0,15,0,0" Height="40" Background="Transparent" BorderBrush="#444" BorderThickness="1" Foreground="#FF5252" FontSize="11" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- GUIDE CARD -->
                <Border Background="#141414" CornerRadius="24" Padding="35" BorderBrush="#222" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="HỖ TRỢ" FontSize="13" FontWeight="Bold" Foreground="#555" Margin="0,0,0,20"/>
                        <TextBlock Text="1. Sao chép ID gửi bộ phận kỹ thuật." Foreground="#999" Margin="0,0,0,12" FontSize="13"/>
                        <TextBlock Text="2. Nhận file license.dat và nhấn Kích hoạt." Foreground="#999" Margin="0,0,0,12" FontSize="13"/>
                        <TextBlock Text="3. Hệ thống tự động mở khóa tính năng." Foreground="#999" FontSize="13"/>
                        
                        <Border Margin="0,30,0,0" Padding="15" Background="#1E2A35" CornerRadius="12">
                            <TextBlock Text="Zalo/Hotline: 084.902.0201" Foreground="#2196F3" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

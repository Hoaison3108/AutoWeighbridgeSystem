<UserControl x:Class="AutoWeighbridgeSystem.Views.QuickVehicleRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="430" Background="Transparent">

    <Border Background="#1E1E1E" CornerRadius="15" BorderBrush="#333" BorderThickness="2" Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ĐĂNG KÝ XE VÃNG LAI" FontSize="20" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Biển số xe:" Foreground="LightGray" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="18" Background="#2D2D2D" Foreground="White" FontWeight="Bold" IsReadOnly="True"
                         Padding="10,0" BorderThickness="0" Margin="0,0,0,15" Height="38" VerticalContentAlignment="Center"/>

                <TextBlock Text="Khách hàng:" Foreground="LightGray" FontSize="13" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="CustomerName"
                          FontSize="16" Background="#2D2D2D" Foreground="White" 
                          Padding="10,0" BorderThickness="0" Margin="0,0,0,15" Height="38" VerticalContentAlignment="Center"/>

                <TextBlock Text="Khối lượng bì (để trống nếu có hàng):" Foreground="LightGray" FontSize="13" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding TareWeight, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" 
                             FontSize="18" Background="#2D2D2D" Foreground="#FFC107" FontWeight="Bold"
                             Padding="10,0" BorderThickness="0" Height="38" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Command="{Binding GetScaleWeightCommand}" 
                            Content=" LẤY SỐ CÂN " Background="#2196F3" Foreground="White" FontWeight="Bold"
                            Height="38" Margin="10,0,0,0" Padding="10,0" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,25,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{Binding CancelCommand}" 
                        Content="HỦY BỎ" Height="42" FontSize="15" FontWeight="Bold" Foreground="White" Cursor="Hand" Background="#555">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="2" Command="{Binding RegisterVehicleCommand}" 
                        Content="XÁC NHẬN" Height="42" FontSize="15" FontWeight="Bold" Foreground="White" Cursor="Hand" Background="#00E676">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>

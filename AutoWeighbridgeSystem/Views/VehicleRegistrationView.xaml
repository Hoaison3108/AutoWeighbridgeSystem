<UserControl x:Class="AutoWeighbridgeSystem.Views.VehicleRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#121212">

    <UserControl.Resources>
        <Style x:Key="RightAlignedColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CenterAlignedColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="LeftAlignedColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D2D" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2196F3" />
            </Style.Resources>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#252525"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="12" Padding="25" Margin="0,0,20,0">
            <StackPanel>
                <TextBlock Text="ĐĂNG KÝ XE &amp; THẺ RFID" FontSize="22" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,25"/>

                <Border BorderBrush="#00E676" BorderThickness="2" CornerRadius="8" Background="#111" Padding="18" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="MÃ THẺ RFID (Quẹt tại bàn)" FontWeight="Bold" Foreground="#00E676" Margin="0,0,0,12"/>
                        <TextBox Text="{Binding NewVehicle.RfidCardId, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" IsReadOnly="True" FontSize="16" Height="48" Background="#252525" Foreground="#FFEB3B" FontWeight="Bold" TextAlignment="Center" VerticalContentAlignment="Center"/>
                        <Button Command="{Binding ClearRfidCommand}" Content="🔃 LÀM MỚI" Background="#424242" Foreground="White" Margin="0,15,0,0" Height="35" FontSize="13"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Biển số xe" Foreground="LightGray" Margin="0,0,0,6"/>
                <TextBox Text="{Binding NewVehicle.LicensePlate, UpdateSourceTrigger=PropertyChanged}" 
                         CharacterCasing="Upper" FontSize="16" FontWeight="Bold" Height="42" Margin="0,0,0,18" 
                         Background="#2D2D2D" Foreground="White" Padding="12,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Khách hàng chủ quản" Foreground="LightGray" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding AllCustomers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="CustomerName"
                          FontSize="15" Margin="0,0,0,18" VerticalContentAlignment="Center"/>

                <TextBlock Text="Trọng lượng bì (kg)" Foreground="LightGray" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             Text="{Binding NewVehicle.TareWeight, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" 
                             FontSize="18" Height="45" Background="#2D2D2D" Foreground="#00E676" 
                             Padding="12,0" VerticalContentAlignment="Center" FontWeight="Bold"/>

                    <Button Grid.Column="1" 
                            Command="{Binding GetWeightFromScaleCommand}"
                            Background="#00E676" Foreground="Black" Margin="10,0,0,0"
                            Content="⚖️">
                        <Button.ToolTip>
                            <ToolTip Content="Lấy khối lượng trực tiếp từ bàn cân"/>
                        </Button.ToolTip>
                    </Button>
                </Grid>

                <CheckBox IsChecked="{Binding SyncTareWeightToAll}" 
                          Content="Đồng bộ Khối lượng thân xe cùng Biển số" 
                          Foreground="#FF9800" 
                          FontSize="14" 
                          FontWeight="SemiBold"
                          Margin="0,-5,0,20"/>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.ColumnSpan="3" Command="{Binding SaveCommand}" Foreground="White">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#FF9800"/>
                                <Setter Property="Content" Value="✏️ CẬP NHẬT THÔNG TIN"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                        <Setter Property="Background" Value="#2196F3"/>
                                        <Setter Property="Content" Value="💾 ĐĂNG KÝ XE MỚI"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Row="2" Grid.Column="0" Command="{Binding DeleteCommand}" Background="#E53935" Foreground="White" Content="🗑️ XÓA XE"/>
                    <Button Grid.Row="2" Grid.Column="2" Command="{Binding ClearFormCommand}" Background="#424242" Foreground="White" Content="🔄 LÀM MỚI"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DANH SÁCH XE ĐÃ ĐĂNG KÝ" FontSize="20" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding RegisteredVehicles}" 
          SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Mã thẻ RFID" Binding="{Binding RfidCardId}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Biển số" Binding="{Binding LicensePlate}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#FFEB3B"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding Customer.CustomerName}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Thân (Kg)" Binding="{Binding TareWeight, StringFormat=N0}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
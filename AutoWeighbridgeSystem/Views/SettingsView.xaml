<UserControl x:Class="AutoWeighbridgeSystem.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:AutoWeighbridgeSystem.ViewModels"
             xmlns:conv="clr-namespace:AutoWeighbridgeSystem.Converters" 
             mc:Ignorable="d" 
             Background="#121212" d:DesignHeight="900" d:DesignWidth="1200">

    <UserControl.Resources>
        <conv:IdToEnabledConverter x:Key="IdToEnabledConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="CenterHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="15" FontWeight="Bold" Foreground="#2196F3" Margin="5,0,0,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="#1E1E1E" Margin="0,0,5,0" CornerRadius="8,8,0,0" Padding="25,12">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2196F3"/>
                                <Setter Property="TextBlock.Foreground" Value="White"/>
                                <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="TextBlock.Foreground" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#00E676" Margin="5,0,0,5"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <TabControl Background="Transparent" BorderThickness="0">
            <TabItem Header="⚙️ CẤU HÌNH THIẾT BỊ">
                <Border Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,15,0,0">
                    <!-- Wrapper Grid: chứa cả nội dung và overlay khóa -->
                    <Grid>
                    <!-- Lớp 1: Nội dung chính -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="THAM SỐ VẬN HÀNH HỆ THỐNG" FontSize="18" FontWeight="Bold" Foreground="#2196F3" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Command="{Binding RefreshComPortsCommand}" Content="🔄 LÀM MỚI DANH SÁCH COM" Width="220" Height="35" Background="#3F51B5" Foreground="White" ToolTip="Nhấn nút này nếu bạn vừa cắm lại dây cáp vào cổng USB khác."/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Expander Header="📏 THAM SỐ ĐẦU CÂN (WEIGHING SCALE)" IsExpanded="True">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,5,0">
                                                <TextBlock Text="Protocol:" Style="{StaticResource LabelStyle}"/>
                                                <ComboBox ItemsSource="{Binding SupportedProtocols}" SelectedItem="{Binding ScaleProtocol}" Height="32"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                                <TextBlock Text="Cổng COM:" Style="{StaticResource LabelStyle}"/>
                                                <ComboBox IsEditable="True" ItemsSource="{Binding AvailableComPorts}" Text="{Binding ScaleComPort}" Height="32"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="5,0,5,0">
                                                <TextBlock Text="BaudRate:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleBaudRate}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Margin="5,0,5,0">
                                                <TextBlock Text="DataBits:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleDataBits}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" Margin="5,0,5,0">
                                                <TextBlock Text="Parity:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleParity}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="5" Margin="5,0,0,0">
                                                <TextBlock Text="StopBits:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleStopBits}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,15,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,5,0">
                                                <TextBlock Text="Tên hàng mặc định:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleDefaultProduct}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                                <TextBlock Text="Ngưỡng (kg):" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleMinWeight}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="5,0,5,0">
                                                <TextBlock Text="RFID Cooldown (s):" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleRfidCooldown}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Margin="5,0,5,0">
                                                <TextBlock Text="Hàng chờ (s):" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleQueueTimeout}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" Margin="5,0,5,0">
                                                <TextBlock Text="Watchdog (s):" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleWatchdog}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="5" Margin="5,0,5,0">
                                                <TextBlock Text="Độ ổn định (kg):" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ScaleStabilityDelta}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="6" Margin="15,0,0,0" VerticalAlignment="Bottom">
                                                <CheckBox Content="Mặc định CÂN XE AUTO" IsChecked="{Binding DefaultToAutoMode}" Foreground="#00E676" Margin="0,0,0,4" FontWeight="Bold"/>
                                                <CheckBox Content="Mặc định CÂN XE 1 LẦN" IsChecked="{Binding DefaultToOnePassMode}" Foreground="#00E676" Margin="0,0,0,4" FontWeight="Bold"/>
                                                <CheckBox Content="Mặc định ĐĂNG KÝ AUTO" IsChecked="{Binding RegistrationDefaultAutoMode}" Foreground="#00E676" Margin="0,0,0,4" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="🏷️ HỆ THỐNG ĐẦU ĐỌC RFID (3 CỔNG CHI TIẾT)" IsExpanded="False" Margin="0,10">
                                    <WrapPanel Orientation="Horizontal">
                                        <GroupBox Header="CHIỀU VÀO (SCALE IN)" Width="385" Margin="0,0,10,10">
                                            <StackPanel Margin="5">
                                                <UniformGrid Columns="2">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="ComPort:" Style="{StaticResource LabelStyle}"/>
                                                        <ComboBox IsEditable="True" ItemsSource="{Binding AvailableComPorts}" Text="{Binding RfidInPort}" Height="32"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="BaudRate:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidInBaudRate}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <UniformGrid Columns="3" Margin="0,5,0,0">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="DataBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidInDataBits}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Parity:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidInParity}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="StopBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidInStopBits}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Header="CHIỀU RA (SCALE OUT)" Width="385" Margin="0,0,10,10">
                                            <StackPanel Margin="5">
                                                <UniformGrid Columns="2">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="ComPort:" Style="{StaticResource LabelStyle}"/>
                                                        <ComboBox IsEditable="True" ItemsSource="{Binding AvailableComPorts}" Text="{Binding RfidOutPort}" Height="32"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="BaudRate:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidOutBaudRate}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <UniformGrid Columns="3" Margin="0,5,0,0">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="DataBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidOutDataBits}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Parity:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidOutParity}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="StopBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidOutStopBits}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Header="TẠI BÀN (REGISTRATION)" Width="385" Margin="0,0,0,10">
                                            <StackPanel Margin="5">
                                                <UniformGrid Columns="2">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="ComPort:" Style="{StaticResource LabelStyle}"/>
                                                        <ComboBox IsEditable="True" ItemsSource="{Binding AvailableComPorts}" Text="{Binding RfidDeskPort}" Height="32"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="BaudRate:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidDeskBaudRate}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <UniformGrid Columns="3" Margin="0,5,0,0">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="DataBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidDeskDataBits}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Parity:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidDeskParity}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="StopBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RfidDeskStopBits}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </GroupBox>
                                    </WrapPanel>
                                </Expander>

                                <Expander Header="📷 CAMERA &amp; RELAY &amp; DATABASE" IsExpanded="True">
                                    <WrapPanel>
                                        <GroupBox Header="CAMERA RTSP" Width="385" Margin="0,0,10,10">
                                            <StackPanel Margin="5">
                                                <UniformGrid Columns="2">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="IP Address:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding CamIpAddress}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="RTSP Port:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding CamRtspPort}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Username:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding CamUsername}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Password:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding CamPassword}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <StackPanel Margin="2,5,2,0">
                                                    <TextBlock Text="RTSP URL (Tổng hợp):" Style="{StaticResource LabelStyle}"/>
                                                    <TextBox Text="{Binding CamRtspUrl}" FontSize="10"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Header="ĐIỀU KHIỂN RELAY CHUÔNG" Width="385" Margin="0,0,10,10">
                                            <StackPanel Margin="5">
                                                <UniformGrid Columns="3">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="COM:" Style="{StaticResource LabelStyle}"/>
                                                        <ComboBox IsEditable="True" ItemsSource="{Binding AvailableComPorts}" Text="{Binding RelayComPort}" Height="32"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Baud:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RelayBaudRate}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="DataBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RelayDataBits}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <UniformGrid Columns="3" Margin="0,5,0,0">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Parity:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RelayParity}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="StopBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RelayStopBits}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Chuông (ms):" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding RelayAlarmDuration}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Header="ĐIỀU KHIỂN RELAY ĐÈN" Width="385" Margin="0,0,10,10">
                                            <StackPanel Margin="5">
                                                <UniformGrid Columns="3">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="COM:" Style="{StaticResource LabelStyle}"/>
                                                        <ComboBox IsEditable="True" ItemsSource="{Binding AvailableComPorts}" Text="{Binding SignalLightComPort}" Height="32"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Baud:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding SignalLightBaudRate}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="DataBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding SignalLightDataBits}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <UniformGrid Columns="3" Margin="0,5,0,0">
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Parity:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding SignalLightParity}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="StopBits:" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding SignalLightStopBits}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="2">
                                                        <TextBlock Text="Thời gian (ms):" Style="{StaticResource LabelStyle}"/>
                                                        <TextBox Text="{Binding SignalLightDuration}"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Header="SQL SERVER" Width="385" Margin="0,0,0,10">
                                            <StackPanel Margin="5">
                                                <TextBlock Text="Connection String:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding DbConnectionString}" FontSize="10" Height="45" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </GroupBox>


                                    </WrapPanel>
                                </Expander>

                                <Expander Header="💻 CHẾ ĐỘ VẬN HÀNH - HỆ THỐNG" IsExpanded="True" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox Content="CHẾ ĐỘ VĂN PHÒNG (Chỉ xem dữ liệu, không kết nối phần cứng)" 
                                                      IsChecked="{Binding IsOfficeMode}" 
                                                      Foreground="#FFC107" FontWeight="Bold" FontSize="14" VerticalContentAlignment="Center"/>
                                            <TextBlock Text=" - Dùng cho máy tính không trực tiếp kết nối bàn cân." 
                                                       Foreground="Gray" FontStyle="Italic" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="Thư mục Backup:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox Text="{Binding BackupFolderPath}" Width="300"/>
                                        </StackPanel>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2" Command="{Binding SaveSystemConfigCommand}" 
                                Content="💾 LƯU TOÀN BỘ CẤU HÌNH HỆ THỐNG" 
                                Background="#FF9800" Foreground="Black" Height="50" Margin="0,20,0,0"
                                IsEnabled="{Binding IsAdmin}"/>
                    </Grid>
                    <!-- Lớp 2: Overlay khóa khi không phải Admin -->
                    <Grid Background="#CC121212">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsAdmin}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Border Background="#1A1A2E" CornerRadius="12" 
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Padding="40,30" MinWidth="400">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                <TextBlock Text="KHÔNG CÓ QUYỀN TRUY CẬP" 
                                           FontSize="20" FontWeight="Bold" Foreground="#F44336"
                                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Chức năng này chỉ dành cho tài khoản Admin." 
                                           FontSize="14" Foreground="#AAAAAA"
                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                                <TextBlock Text="Vui lòng liên hệ quản trị viên hệ thống." 
                                           FontSize="13" Foreground="#888888"
                                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="🔌 KẾT NỐI DATABASE">
                <Border Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,15,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="CẤU HÌNH KẾT NỐI MÁY CHỦ DỮ LIỆU" FontSize="18" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,20"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Panel: Discovery -->
                            <GroupBox Header="1. TÌM KIẾM MÁY CHỦ (SCAN)" Margin="0,0,20,0">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Button Command="{Binding DiscoverServersCommand}" Content="🔍 BẮT ĐẦU QUÉT MẠNG LAN" 
                                            Background="#3F51B5" Foreground="White" Height="40" Margin="0,0,0,10"/>

                                    <ListBox Grid.Row="1" ItemsSource="{Binding DiscoveredServers}" 
                                             SelectedItem="{Binding DbServerName}"
                                             Background="#121212" Foreground="White" BorderBrush="#444"
                                             FontSize="14">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="🖥️" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock Grid.Row="2" Text="* Chọn máy chủ từ danh sách để tự điền vào mục cấu hình thủ công." 
                                               Foreground="#888" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                </Grid>
                            </GroupBox>

                            <!-- Right Panel: Manual Configuration -->
                            <GroupBox Grid.Column="1" Header="2. CẤU HÌNH KẾT NỐI THỦ CÔNG (MANUAL)">
                                <StackPanel Margin="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Địa chỉ Server (IP hoặc Hostname):" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding DbServerName}" Height="35"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Tên Cơ sở dữ liệu (Database):" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding DbName}" Height="35"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,15,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Tên đăng nhập (User Id):" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding DbUser}" Height="35"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Mật khẩu (Password):" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding DbPassword}" Height="35"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <StackPanel Margin="0,20,0,0">
                                        <TextBlock Text="Chuỗi kết nối hiện tại (Connection String):" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding DbConnectionString}" Height="60" TextWrapping="Wrap" IsReadOnly="True" Opacity="0.7"/>
                                    </StackPanel>

                                    <UniformGrid Columns="2" Margin="0,20,0,0">
                                        <Button Command="{Binding TestConnectionCommand}" Content="⚡ KIỂM TRA KẾT NỐI" 
                                                Background="#00C853" Foreground="White" Margin="0,0,10,0"/>
                                        <Button Command="{Binding BuildConnectionStringCommand}" Content="🔗 TỔNG HỢP CHUỖI KẾT NỐI" 
                                                Background="#FF9800" Foreground="Black" Margin="10,0,0,0"/>
                                    </UniformGrid>
                                    
                                    <TextBlock Text="* Sau khi nhấn 'Tổng hợp', bạn cần nhấn nút 'LƯU TOÀN BỘ' ở tab Thiết bị để ghi vào file hệ thống." 
                                               Foreground="#2196F3" FontWeight="SemiBold" FontSize="12" Margin="0,15,0,0" TextAlignment="Center"/>
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                        
                        <!-- Overlay khóa khi không phải Admin -->
                        <Grid Background="#CC121212" Grid.RowSpan="2">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsAdmin}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Background="#1A1A2E" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40,30">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="KHÔNG CÓ QUYỀN TRUY CẬP" FontSize="20" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Thay đổi cấu hình Server yêu cầu quyền Admin." Foreground="#AAA" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="💽 BẢO TRÌ &amp; SAO LƯU">
                <Border Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,15,0,0">
                    <Grid>
                        <!-- Lớp 1: Nội dung -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="SAO LƯU DỮ LIỆU TRẠM CÂN (BACKUP)" FontSize="18" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,20"/>
                            
                            <StackPanel Grid.Row="1" Width="500" HorizontalAlignment="Left">
                                <GroupBox Header="TẠO BẢN SAO LƯU (BACKUP) THỦ CÔNG" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Thư mục xuất file Backup (Khuyên dùng Ổ đĩa D):" Style="{StaticResource LabelStyle}" FontSize="13"/>
                                        <TextBox Text="{Binding BackupFolderPath}" Height="40" FontSize="14" Margin="0,5,0,20"/>
                                        
                                        <Button Command="{Binding BackupDatabaseCommand}" 
                                                Content="💽 TIẾN HÀNH SAO LƯU DỮ LIỆU" 
                                                Height="55" FontSize="16" Background="#4CAF50" Foreground="White" 
                                                ToolTip="Hệ thống sẽ tạo ra một file .bak chứa toàn bộ CSDL."/>
                                        
                                        <TextBlock Text="* Định dạng Output: AutoWeighbridgeDB_Backup_Ngày_Giờ.bak" Foreground="#888" FontSize="12" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Lớp 2: Overlay khóa khi không phải Admin -->
                        <Grid Background="#CC121212">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsAdmin}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Background="#1A1A2E" CornerRadius="12" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Padding="40,30" MinWidth="400">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="KHÔNG CÓ QUYỀN TRUY CẬP" 
                                               FontSize="20" FontWeight="Bold" Foreground="#F44336"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Chức năng Backup chỉ dành cho Admin." 
                                               FontSize="14" Foreground="#AAAAAA"
                                               HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="👤 NGƯỜI DÙNG">
                <Border Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,15,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="QUẢN TRỊ TÀI KHOẢN TRUY CẬP" FontSize="18" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,20"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding UserList}" SelectedItem="{Binding GridSelectedUser}" 
                                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                  Background="Transparent" RowHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã ID" Binding="{Binding Id}" Width="80">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CenterHeaderStyle}"/>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding Username}" Width="150">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CenterHeaderStyle}"/>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="15,0,0,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="*">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CenterHeaderStyle}"/>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="15,0,0,0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Quyền hạn" Binding="{Binding Role}" Width="150">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CenterHeaderStyle}"/>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#00E676"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridCheckBoxColumn Header="Đang hoạt động" Binding="{Binding IsActive}" Width="130">
                                    <DataGridCheckBoxColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CenterHeaderStyle}"/>
                                    </DataGridCheckBoxColumn.HeaderStyle>
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
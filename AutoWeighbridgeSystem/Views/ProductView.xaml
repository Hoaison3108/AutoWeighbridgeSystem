<UserControl x:Class="AutoWeighbridgeSystem.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:AutoWeighbridgeSystem.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="#121212">

    <UserControl.Resources>
        <Style x:Key="CenterAlignedColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="LeftAlignedColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2196F3"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2196F3"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <!-- Dành cho ô nhập liệu (TextBox) và nền tổng thể: Trắng chuẩn -->
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2196F3" />
                
                <!-- Hiển thị chữ xanh trên nền trắng -->
                <Style TargetType="TextBox">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="#2196F3"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#252525"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút bật tắt ComboBox siêu to khổng lồ dành cho trạm cân cảm ứng (Touch-friendly) -->
        <Style x:Key="BigDropdownButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="50"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Background" Value="#455A64"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="▼" FontFamily="Segoe UI Symbol" FontSize="20" FontWeight="Bold" Margin="0,2,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00E676"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="12" Padding="25" Margin="0,0,20,0">
            <StackPanel>
                <TextBlock Text="DANH MỤC SẢN PHẨM" FontSize="22" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,25"/>

                <TextBlock Text="Mã sản phẩm (Tối đa 8 ký tự)" Foreground="LightGray" Margin="0,0,0,6"/>
                <TextBox Text="{Binding SelectedProduct.ProductId, UpdateSourceTrigger=PropertyChanged}" 
                         IsReadOnly="{Binding IsEditMode}"
                         MaxLength="8"
                         FontSize="17" Height="42" Margin="0,0,0,15" Background="#2D2D2D" Foreground="#00E676" 
                         Padding="12,0" VerticalContentAlignment="Center" FontWeight="Bold">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Text="Tên sản phẩm / Loại hàng (Gõ hoặc chọn nhanh)" Foreground="LightGray" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SelectedProduct.ProductName, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="17" Height="42" Background="#2D2D2D" Foreground="#2196F3" 
                             Padding="12,0" VerticalContentAlignment="Center" FontWeight="Bold" Margin="0,0,5,0"/>
                    
                    <ComboBox x:Name="ProductComboBox"
                              Grid.Column="1"
                              ItemsSource="{Binding ProductAutocomplete.View}"
                              Text="{Binding SelectedProduct.ProductName, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Height="42" FontSize="16"
                              TextBoxBase.TextChanged="ProductComboBox_TextChanged"
                              ToolTip="Gõ để lọc hoặc chọn từ danh sách hàng hóa sẵn có"/>

                    <ToggleButton Grid.Column="1" 
                                  Style="{StaticResource BigDropdownButtonStyle}" 
                                  IsChecked="{Binding IsDropDownOpen, ElementName=ProductComboBox}" />
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding SaveCommand}" Foreground="White">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#FF9800"/>
                                <Setter Property="Content" Value="✏️ CẬP NHẬT"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                        <Setter Property="Background" Value="#2196F3"/>
                                        <Setter Property="Content" Value="💾 THÊM MỚI"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="2" Command="{Binding ClearFormCommand}" Content="🔄 LÀM MỚI" Background="#424242" Foreground="White"/>
                </Grid>

                <Button Command="{Binding DeleteCommand}" Content="🗑️ XÓA SẢN PHẨM" Background="#E53935" Foreground="White" Margin="0,20,0,0" Height="40"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="DANH SÁCH HÀNG HÓA" FontSize="20" FontWeight="Bold" Foreground="#2196F3" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="🔍 TÌM KIẾM:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11" FontWeight="Bold"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="32" 
                                 Background="#252525" Foreground="White" BorderBrush="#444" VerticalContentAlignment="Center" Padding="8,0"/>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding ProductListView}" 
          SelectedItem="{Binding GridSelectedItem, Mode=TwoWay}" 
          AutoGenerateColumns="False" IsReadOnly="True" 
          Background="Transparent" SelectionMode="Single">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Mã Hệ thống" Binding="{Binding ProductId}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tên sản phẩm / Loại hàng" Binding="{Binding ProductName}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#00E676"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
<UserControl x:Class="AutoWeighbridgeSystem.Views.WeighingHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:AutoWeighbridgeSystem.ViewModels"
             xmlns:conv="clr-namespace:AutoWeighbridgeSystem.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#121212">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Đảo ngược bool: IsVoid=True → nút SỬA bị disabled -->
        <conv:InverseBooleanConverter x:Key="InvertBool"/>

        <Style x:Key="CenterAlignedStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RightAlignedStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D2D2D"/>
                        <Setter Property="Foreground" Value="#BBBBBB"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#333"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== THANH TÌM KIẾM ===== -->
        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="📅 TỪ NGÀY" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding FromDate}" Width="160" Height="35" Background="#2D2D2D"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="📅 ĐẾN NGÀY" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding ToDate}" Width="160" Height="35"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="🔍 TÌM KIẾM NHANH (BIỂN SỐ / KHÁCH)" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="300" Height="35" Background="#2D2D2D" Foreground="White" 
                                 VerticalContentAlignment="Center" Padding="10,0" BorderThickness="1" BorderBrush="#444">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoadHistoryCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <Button Command="{Binding LoadHistoryCommand}" Content="TRA CỨU" 
                            Background="#2196F3" Foreground="White" Width="120" Height="35" Margin="0,18,10,0" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Command="{Binding ExportExcelCommand}" Content="XUẤT EXCEL" 
                            Background="#388E3C" Foreground="White" Width="120" Height="35" Margin="0,18,0,0" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== THỐNG KÊ ===== -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">
            <Border Background="#252525" Margin="0,0,10,0" Padding="15" CornerRadius="8" BorderBrush="#2196F3" BorderThickness="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="TỔNG SỐ CHUYẾN CÂN" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{Binding TotalVehicles}" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#252525" Margin="5,0,5,0" Padding="15" CornerRadius="8" BorderBrush="#00E676" BorderThickness="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="TỔNG TRỌNG LƯỢNG (KG)" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{Binding TotalGross, StringFormat=N0}" Foreground="#00E676" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#252525" Margin="10,0,0,0" Padding="15" CornerRadius="8" BorderBrush="#FFEB3B" BorderThickness="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="TỔNG HÀNG THỰC (NET)" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{Binding TotalNet, StringFormat=N0}" Foreground="#FFEB3B" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ===== BẢNG DỮ LIỆU ===== -->
        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="8" Padding="10" BorderBrush="#333" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Tickets}" SelectedItem="{Binding SelectedTicket}" 
          AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="STT" Width="50">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" ToolTip="{Binding Status}" 
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding TicketID}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Biển Số" Binding="{Binding LicensePlate}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#2196F3"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Khách Hàng" Binding="{Binding CustomerName}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Sản Phẩm" Binding="{Binding ProductName}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Giờ Vào" Binding="{Binding TimeIn, StringFormat='HH:mm:ss'}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Giờ Ra" Binding="{Binding TimeOut, StringFormat='HH:mm:ss'}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Tổng (Kg)" Binding="{Binding GrossWeight, StringFormat=N0}" Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Thân (Kg)" Binding="{Binding TareWeight, StringFormat=N0}" Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Hàng (Kg)" Binding="{Binding NetWeight, StringFormat=N0}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                                <Setter Property="Foreground" Value="#FFEB3B"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Thao Tác" Width="*">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- In phiếu -->
                                    <Button Command="{Binding DataContext.PrintTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}"
                                            Content="🖨️" Background="#333" Width="35" Height="28" Margin="2" BorderThickness="0"
                                            ToolTip="In phiếu cân"/>
                                    <!-- Nút SỬA: disabled khi phiếu đã bị hủy (IsVoid=True) -->
                                    <Button Command="{Binding DataContext.SelectForEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}"
                                            Content="✏️ SỬA" Background="#1565C0" Foreground="White" Width="65" Height="28" Margin="2" FontSize="10" FontWeight="Bold" BorderThickness="0"
                                            IsEnabled="{Binding IsVoid, Converter={StaticResource InvertBool}}"
                                            ToolTip="Chỉnh sửa khối lượng phiếu này"/>
                                    <!-- Hủy phiếu -->
                                    <Button Command="{Binding DataContext.VoidTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}"
                                            Content="HỦY" Background="#C62828" Foreground="White" Width="55" Height="28" Margin="2" FontSize="10" FontWeight="Bold" BorderThickness="0"
                                            ToolTip="Hủy phiếu cân"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- =====================================================================
             PANEL CHỈNH SỬA KHỐI LƯỢNG
             Hiển thị khi IsEditPanelVisible=True (bấm nút SỬA trên 1 dòng)
             ===================================================================== -->
        <Border Grid.Row="3"
                Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVis}}"
                Background="#1A2744" CornerRadius="10" Padding="20,15"
                Margin="0,12,0,0" BorderBrush="#2196F3" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- TIÊU ĐỀ PANEL -->
                <StackPanel Grid.Column="0" Margin="0,0,30,0" VerticalAlignment="Center">
                    <TextBlock Text="✏️ CHỈNH SỬA PHIẾU" FontSize="13" FontWeight="Bold" Foreground="#2196F3"/>
                    <TextBlock Text="{Binding SelectedTicket.TicketID, StringFormat='Mã: {0}'}" Foreground="#888" FontSize="11" Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding SelectedTicket.LicensePlate, StringFormat='Xe: {0}'}" Foreground="#AAA" FontSize="11"/>
                </StackPanel>

                <!-- CÁC Ô NHẬP LIỆU -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- GrossWeight -->
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="TỔNG CỘNG (GROSS)" Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding EditGrossWeight, UpdateSourceTrigger=PropertyChanged}"
                                     Width="130" Height="36" Background="#2D2D2D" Foreground="White"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="#2196F3" BorderThickness="1" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text=" kg" Foreground="#888" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- TareWeight -->
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="THÂN XE (TARE)" Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding EditTareWeight, UpdateSourceTrigger=PropertyChanged}"
                                     Width="130" Height="36" Background="#2D2D2D" Foreground="White"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="#555" BorderThickness="1" FontSize="14"/>
                            <TextBlock Text=" kg" Foreground="#888" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- NetWeight — chỉ đọc, tự tính -->
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="HÀNG THỰC (NET) — TỰ TÍNH" Foreground="#888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Border Background="#0A2A0A" CornerRadius="4" BorderBrush="#00E676" BorderThickness="1" Padding="12,0" Height="36">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding EditNetWeight, StringFormat=N0}" Foreground="#00E676"
                                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" kg" Foreground="#888" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Lý do chỉnh sửa -->
                    <StackPanel MinWidth="230">
                        <TextBlock Text="LÝ DO CHỈNH SỬA (BẮT BUỘC)" Foreground="#F57C00" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Background="#2D2D2D" Foreground="White"
                                 VerticalContentAlignment="Center" Padding="8,0"
                                 BorderBrush="#F57C00" BorderThickness="1"/>
                    </StackPanel>
                </StackPanel>

                <!-- NÚT HÀNH ĐỘNG -->
                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" Margin="20,0,0,0">
                    <!-- Nút CẬP NHẬT: disable khi IsSaving=True (DataTrigger) -->
                    <Button Command="{Binding UpdateWeightCommand}"
                            Height="40" Width="140" Margin="0,0,0,8"
                            FontWeight="Bold" FontSize="13" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1565C0"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Content" Value="💾 CẬP NHẬT"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                        <Setter Property="Content" Value="⏳ Đang lưu..."/>
                                        <Setter Property="Background" Value="#555"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Nút HỦY BỎ chỉnh sửa -->
                    <Button Command="{Binding CancelEditCommand}"
                            Content="❌ HỦY BỎ" Height="32" Width="140"
                            Background="#424242" Foreground="#CCC" FontSize="11"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
<Window x:Class="AutoWeighbridgeSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Nhập Hệ Thống" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#1E1E1E" CornerRadius="15" BorderBrush="#333" BorderThickness="2" Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock Text="⚖️" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="TRẠM CÂN TỰ ĐỘNG" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="KHOÁNG SẢN RẠNG ĐÔNG" FontSize="14" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Tên đăng nhập:" Foreground="LightGray" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="16" Background="#2D2D2D" Foreground="White" 
                         Padding="10,0" BorderThickness="0" Margin="0,0,0,15" Height="38" VerticalContentAlignment="Center"/>

                <TextBlock Text="Mật khẩu:" Foreground="LightGray" FontSize="13" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" 
                             FontSize="16" Background="#2D2D2D" Foreground="White" 
                             Padding="10,0" BorderThickness="0" Margin="0,0,0,10" Height="38" VerticalContentAlignment="Center">
                    <PasswordBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=txtPassword}"/>
                    </PasswordBox.InputBindings>
                </PasswordBox>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10" 
                           TextWrapping="Wrap" TextAlignment="Center" Height="35" FontSize="12"/>

                <Button Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=txtPassword}" 
                        Content="ĐĂNG NHẬP" Height="42" FontSize="15" FontWeight="Bold" Foreground="White" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2196F3"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity" Value="0.5"/>
                                    <Setter Property="Content" Value="ĐANG KIỂM TRA..."/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <Button Grid.Row="1" Click="BtnExit_Click" Content="Thoát" 
                    Background="Transparent" Foreground="Gray" BorderThickness="0" Cursor="Hand" Margin="0,15,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" Background="Transparent" 
                                   TextDecorations="Underline" HorizontalAlignment="Center" FontSize="12"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>